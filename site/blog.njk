---
layout: base.njk
title: Blog
description: Updates and articles about L10N.md
permalink: /blog/index.html
---

<article class="blog-index">
  <header class="spec-head">
    <p class="spec-eyebrow">Updates</p>
    <h1 class="spec-title">Blog</h1>
    <p class="spec-subtitle">News, updates, and articles about L10N.md</p>
  </header>

  <div class="blog-posts">
    {% for post in blog %}
    <article class="blog-post-summary">
      <h2><a href="/blog/{{ post.slug }}/">{{ post.title }}</a></h2>
      <p class="blog-meta">
        <time datetime="{{ post.date }}">{{ post.date }}</time>
        {% if post.author %}<span class="blog-author">{{ post.author }}</span>{% endif %}
      </p>
      <p class="blog-description">{{ post.description }}</p>
    </article>
    {% endfor %}
  </div>
</article>
