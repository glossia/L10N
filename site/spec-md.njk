---
specFormat: markdown
pagination:
  data: specPages
  size: 1
  alias: specPage
permalink: "/v{{ specPage.spec.version }}/{% if specPage.locale.code != 'en' %}{{ specPage.locale.code }}/{% endif %}spec.md"
eleventyExcludeFromCollections: true
---
{%- set spec = specPage.spec -%}
{%- set locale = specPage.locale -%}
{%- set sections = specPage.sections -%}
{%- set referenceVersion = reference.byVersion[spec.version] -%}
# {{ site.spec.name }} - Specification v{{ spec.version }} ({{ locale.label }})

> {{ site.spec.subtitle }}

Status: {{ site.spec.status }}
Version: {{ spec.version }}
Updated: {{ site.spec.updated }}
Source: {{ site.repo }}
License: {{ site.spec.license }}

---

{% for section in sections -%}
{%- if section.kind == "preamble" -%}
## {{ section.label or section.title }}

{{ section.body | renderNunjucks | safe }}

{% elif section.kind == "section" -%}
## {{ section.number }}. {{ section.title }}

{{ section.body | renderNunjucks | safe }}

{% elif section.kind == "appendix" -%}
## Appendix {{ section.number }}. {{ section.title }}

{{ section.body | renderNunjucks | safe }}

{% endif -%}
{% endfor %}
