{
  "$id": "https://glossia.dev/schemas/l10n/v1/shared.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "localeIdentifier": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(?:[-_][A-Za-z0-9]{2,8})*$",
      "examples": ["en", "es", "ja", "zh_Hant"]
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "markdownBody": {
      "type": "string",
      "minLength": 1
    },
    "extensionFields": {
      "type": "object",
      "patternProperties": {
        "^x-": true
      }
    }
  }
}
